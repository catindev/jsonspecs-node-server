      "type": "rule",
      "description": "Категория товара должна быть разрешена к возврату без брака",
      "role": "check",
      "operator": "in_dictionary",
      "field": "return.items[*].category",
      "dictionary": {
        "type": "static",
        "id": "library.dictionaries.returnable_categories"
      },
      "level": "ERROR",
      "code": "7008",
      "message": "Эту категорию товара можно вернуть только при браке"
    },
    {
      "id": "entrypoints.return.request.return.items_qty_positive",
      "type": "rule",
      "description": "Количество к возврату должно быть больше нуля для каждой позиции",
      "role": "check",
      "operator": "greater_than",
      "field": "return.items[*].returnQty",
      "value": 0,
      "aggregate": {
        "mode": "EACH",
        "onEmpty": "FAIL"
      },
      "level": "ERROR",
      "code": "7005",
      "message": "Укажите количество товара к возврату"
    },
    {
      "id": "entrypoints.return.request.return.items_sku_format",
      "type": "rule",
      "description": "Артикул возвращаемой позиции должен соответствовать формату магазина",
      "role": "check",
      "operator": "matches_regex",
      "field": "return.items[*].sku",
      "value": "^[A-Z]{3}-\\d{4}$",
      "level": "ERROR",
      "code": "7006",
      "message": "Проверьте артикул возвращаемого товара"
    },
    {
      "id": "entrypoints.return.request.return.cond_non_defect_checks",
      "type": "condition",
      "description": "Если возврат не из-за брака, проверить категорию и показать предупреждение",
      "when": "entrypoints.return.request.return.pred_reason_not_defect",
      "steps": [
        {
          "rule": "entrypoints.return.request.return.category_returnable"
        },
        {
          "rule": "entrypoints.return.request.return.non_defect_quality_check_warning"
        }
      ]
    },
    {
      "id": "entrypoints.return.request.return.non_defect_quality_check_warning",
      "type": "rule",
      "description": "При возврате без брака деньги вернутся после проверки качества",
      "role": "check",
      "operator": "equals",
      "field": "return.reason",
      "value": "DEFECT",
      "level": "WARNING",
      "code": "7009",
      "message": "Деньги вернутся после проверки товара, это может занять до двух недель"
    },
    {
      "id": "entrypoints.return.request.return.order_id_required",
      "type": "rule",
      "description": "Номер заказа обязателен для заявки на возврат",
      "role": "check",
      "operator": "not_empty",
      "field": "order.id",
      "level": "ERROR",
      "code": "7001",
      "message": "Не указан номер заказа"
    },
    {
      "id": "entrypoints.return.request.return.order_status_returnable",
      "type": "rule",
      "description": "Состояние заказа должно допускать возврат",
      "role": "check",
      "operator": "in_dictionary",
      "field": "order.status",
      "dictionary": {
        "type": "static",
        "id": "library.dictionaries.returnable_order_statuses"
      },
      "level": "ERROR",
      "code": "7002",
      "message": "Возврат доступен только для полученного заказа"
    },
    {
      "id": "entrypoints.return.request.return.reason_allowed",
      "type": "rule",
      "description": "Причина возврата должна поддерживаться магазином",
      "role": "check",
      "operator": "in_dictionary",
      "field": "return.reason",
      "dictionary": {
        "type": "static",
        "id": "library.dictionaries.return_reasons"
      },
      "level": "ERROR",
      "code": "7004",
      "message": "Выберите причину возврата из списка"
    },
    {
      "id": "entrypoints.return.request.return.pred_reason_not_defect",
      "type": "rule",
      "description": "Причина возврата не связана с браком",
      "role": "predicate",
      "operator": "not_equals",
      "field": "return.reason",
      "value": "DEFECT"
    },
    {
      "id": "entrypoints.return.request.return.return_deadline_not_expired",
      "type": "rule",
      "description": "Срок возврата не должен быть раньше текущей даты",
      "role": "check",
      "operator": "field_greater_or_equal_than_field",
      "field": "order.returnDeadline",
      "value_field": "$context.currentDate",
      "level": "ERROR",
      "code": "7003",
      "message": "Срок возврата по этому заказу истёк"
    },
    {
      "id": "entrypoints.return.request",
      "type": "pipeline",
      "description": "Проверка заявки на возврат товара",
      "entrypoint": true,
      "strict": false,
      "required_context": [
        "currentDate"
      ],
      "flow": [
        {
          "pipeline": "library.checkout.pipe_customer_basics",
          "stepId": "customer_basics"
        },
        {
          "rule": "entrypoints.return.request.return.order_id_required",
          "stepId": "return_order_id_required"
        },
        {
          "rule": "entrypoints.return.request.return.order_status_returnable",
          "stepId": "return_order_status_returnable"
        },
        {
          "rule": "entrypoints.return.request.return.return_deadline_not_expired",
          "stepId": "return_deadline_not_expired"
        },
        {
          "rule": "entrypoints.return.request.return.reason_allowed",
          "stepId": "return_reason_allowed"
        },
        {
          "rule": "entrypoints.return.request.return.items_qty_positive",
          "stepId": "return_items_qty_positive"
        },
        {
          "rule": "entrypoints.return.request.return.items_sku_format",
          "stepId": "return_items_sku_format"
        },
        {
          "rule": "entrypoints.return.request.return.amount_not_greater_than_order",
          "stepId": "return_amount_not_greater_than_order"
        },
        {
          "condition": "entrypoints.return.request.return.cond_non_defect_checks",
          "stepId": "return_non_defect_checks"
        }
      ]
    },
    {
      "id": "library.checkout.customer.cond_email_format_if_present",
      "type": "condition",
      "description": "Если электронная почта заполнена, проверить её формат",
      "when": "library.checkout.customer.pred_email_filled",
      "steps": [
        {
          "rule": "library.checkout.customer.email_format"
        }
      ]
    },
    {
      "id": "library.checkout.customer.cond_phone_format_if_present",
      "type": "condition",
      "description": "Если телефон заполнен, проверить его формат",
      "when": "library.checkout.customer.pred_phone_filled",
      "steps": [
        {
          "rule": "library.checkout.customer.phone_format"
        }
      ]
    },
    {
      "id": "library.checkout.delivery.cond_courier_checks",
      "type": "condition",
      "description": "Проверки, применимые только к курьерской доставке",
      "when": "library.checkout.delivery.pred_type_courier",
      "steps": [
        {
          "rule": "library.checkout.delivery.address_required"
        },
        {
          "rule": "library.checkout.delivery.region_allowed"
        }
      ]
    },
    {
      "id": "library.checkout.delivery.cond_pickup_checks",
      "type": "condition",
      "description": "Проверки, применимые только к самовывозу",
      "when": "library.checkout.delivery.pred_type_pickup",
      "steps": [
        {
          "rule": "library.checkout.delivery.pickup_point_required"
        }
      ]
    },
    {
      "id": "library.checkout.order.cond_amount_min_if_present",
      "type": "condition",
      "description": "Если сумма заказа заполнена, проверить минимальную сумму",
      "when": "library.checkout.order.pred_amount_filled",
      "steps": [
        {
          "rule": "library.checkout.order.amount_min"
        }
      ]
    },
    {
      "id": "library.checkout.customer.contact_required",
      "type": "rule",
      "description": "Должен быть указан хотя бы один способ связи",
      "role": "check",
      "operator": "any_filled",
      "fields": [
        "customer.phone",
        "customer.email"
      ],
      "level": "ERROR",
      "code": "1002",
      "message": "Укажите телефон или электронную почту"
    },
    {
      "id": "library.checkout.customer.email_format",
      "type": "rule",
      "description": "Электронная почта должна быть похожа на настоящий адрес",
      "role": "check",
      "operator": "matches_regex",
      "field": "customer.email",
      "value": "^[^@\\s]+@[^@\\s]+\\.[^@\\s]+$",
      "level": "ERROR",
      "code": "1004",
      "message": "Проверьте адрес электронной почты"
    },
    {
      "id": "library.checkout.customer.name_required",
      "type": "rule",
      "description": "Имя покупателя обязательно",
      "role": "check",
      "operator": "not_empty",
      "field": "customer.name",
      "level": "ERROR",
      "code": "1001",
      "message": "Укажите имя получателя"
    },
    {
      "id": "library.checkout.customer.phone_format",
      "type": "rule",
      "description": "Телефон должен быть российским мобильным номером",
      "role": "check",
      "operator": "matches_regex",
      "field": "customer.phone",
      "value": "^\\+7\\d{10}$",
      "level": "ERROR",
      "code": "1003",
      "message": "Проверьте номер телефона"
    },
    {
      "id": "library.checkout.delivery.address_required",
      "type": "rule",
      "description": "Адрес обязателен для курьерской доставки",
      "role": "check",
      "operator": "not_empty",
      "field": "delivery.address",
      "level": "ERROR",
      "code": "4002",
      "message": "Укажите адрес доставки"
    },
    {
      "id": "library.checkout.delivery.pickup_point_required",
      "type": "rule",
      "description": "Пункт выдачи обязателен для самовывоза",
      "role": "check",
      "operator": "not_empty",
      "field": "delivery.pickupPointId",
      "level": "ERROR",
      "code": "4004",
      "message": "Выберите пункт выдачи"
    },
    {
      "id": "library.checkout.delivery.region_allowed",
      "type": "rule",
      "description": "Регион должен входить в зону курьерской доставки",
      "role": "check",
      "operator": "in_dictionary",
      "field": "delivery.regionCode",
      "dictionary": {
        "type": "static",
        "id": "library.dictionaries.courier_region_codes"
      },
      "level": "ERROR",
      "code": "4003",
      "message": "Курьерская доставка недоступна в выбранном регионе"
    },
    {
      "id": "library.checkout.delivery.type_allowed",
      "type": "rule",
      "description": "Способ доставки должен поддерживаться магазином",
      "role": "check",
      "operator": "in_dictionary",
      "field": "delivery.type",
      "dictionary": {
        "type": "static",
        "id": "library.dictionaries.delivery_types"
      },
      "level": "ERROR",
      "code": "4001",
      "message": "Выберите поддерживаемый способ доставки"
    },
    {
      "id": "library.dictionaries.b2b_payment_methods",
      "type": "dictionary",
      "description": "Поддерживаемые способы оплаты для B2B-заказа",
      "entries": [
        "INVOICE"
      ]
    },
    {
      "id": "library.dictionaries.contact_channels",
      "type": "dictionary",
      "description": "Поддерживаемые каналы связи с покупателем",
      "entries": [
        "CALL",
        "SMS",
        "EMAIL"
      ]
    },
    {
      "id": "library.dictionaries.courier_region_codes",
      "type": "dictionary",
      "description": "Регионы, доступные для курьерской доставки",
      "entries": [
        "77",
        "50",
        "78",
        "47",
        "66"
      ]
    },
    {
      "id": "library.dictionaries.delivery_types",
      "type": "dictionary",
      "description": "Поддерживаемые способы доставки",
      "entries": [
        "COURIER",
        "PICKUP"
      ]
    },
    {
      "id": "library.dictionaries.order_currencies",
      "type": "dictionary",
      "description": "Поддерживаемые валюты заказа",
      "entries": [
        "RUB"
      ]
    },
    {
      "id": "library.dictionaries.payment_methods",
      "type": "dictionary",
      "description": "Поддерживаемые способы оплаты",
      "entries": [
        "CARD",
        "SBP",
        "CASH"
      ]
    },
    {
      "id": "library.dictionaries.return_reasons",
      "type": "dictionary",
      "description": "Поддерживаемые причины возврата",
      "entries": [
        "DEFECT",
        "WRONG_ITEM",
        "NOT_SUITED",
        "CHANGED_MIND"
      ]
    },
    {
      "id": "library.dictionaries.returnable_categories",
      "type": "dictionary",
      "description": "Категории товаров, разрешённые к возврату без брака",
      "entries": [
        "BOOKS",
        "STATIONERY",
        "TOYS",
        "OFFICE"
      ]
    },
    {
      "id": "library.dictionaries.returnable_order_statuses",
      "type": "dictionary",
      "description": "Состояния заказа, допускающие возврат",
      "entries": [
        "DELIVERED",
        "PICKED_UP"
      ]
    },
    {
      "id": "library.checkout.order.amount_min",
      "type": "rule",
      "description": "Сумма заказа должна быть не ниже минимальной суммы из контекста",
      "role": "check",
      "operator": "field_greater_or_equal_than_field",
      "field": "order.amount",
      "value_field": "$context.minOrderAmount",
      "level": "ERROR",
      "code": "2002",
      "message": "Сумма заказа меньше минимальной"
    },
    {
      "id": "library.checkout.order.amount_required",
      "type": "rule",
      "description": "Сумма заказа обязательна",
      "role": "check",
      "operator": "not_empty",
      "field": "order.amount",
      "level": "ERROR",
      "code": "2001",
      "message": "Не указана сумма заказа"
    },
    {
      "id": "library.checkout.order.currency_allowed",
      "type": "rule",
      "description": "Валюта заказа должна поддерживаться магазином",
      "role": "check",
      "operator": "in_dictionary",
      "field": "order.currency",
      "dictionary": {
        "type": "static",
        "id": "library.dictionaries.order_currencies"
      },
      "level": "ERROR",
      "code": "2003",
      "message": "Магазин принимает оплату только в рублях"
    },
    {
      "id": "library.checkout.order.items_qty_positive",
      "type": "rule",
      "description": "Корзина не должна быть пустой, количество каждой позиции должно быть больше нуля",
      "role": "check",
      "operator": "greater_than",
      "field": "order.items[*].qty",
      "value": 0,
      "aggregate": {
        "mode": "EACH",
        "onEmpty": "FAIL"
      },
      "level": "ERROR",
      "code": "2004",
      "message": "Корзина пуста или количество товара указано неверно"
    },
    {
      "id": "library.checkout.order.items_sku_format",
      "type": "rule",
      "description": "Артикул каждой позиции должен соответствовать формату магазина",
      "role": "check",
      "operator": "matches_regex",
      "field": "order.items[*].sku",
      "value": "^[A-Z]{3}-\\d{4}$",
      "level": "ERROR",
      "code": "2005",
      "message": "Проверьте артикул товара"
    },
    {
      "id": "library.checkout.pipe_customer_basics",
      "type": "pipeline",
      "description": "Общие проверки покупателя: имя, наличие контакта и форматы контактов",
      "entrypoint": false,
      "strict": false,
      "flow": [
        {
          "rule": "library.checkout.customer.name_required",
          "stepId": "customer_name_required"
        },
        {
          "rule": "library.checkout.customer.contact_required",
          "stepId": "customer_contact_required"
        },
        {
          "condition": "library.checkout.customer.cond_phone_format_if_present",
          "stepId": "customer_phone_format_if_present"
        },
        {
          "condition": "library.checkout.customer.cond_email_format_if_present",
          "stepId": "customer_email_format_if_present"
        }
      ]
    },
    {
      "id": "library.checkout.pipe_delivery_basics",
      "type": "pipeline",
      "description": "Общие проверки доставки: используются и в обычном, и в B2B-заказе",
      "entrypoint": false,
      "strict": false,
      "flow": [
        {
          "rule": "library.checkout.delivery.type_allowed",
          "stepId": "delivery_type_allowed"
        },
        {
          "condition": "library.checkout.delivery.cond_courier_checks",
          "stepId": "delivery_courier_checks"
        },
        {
          "condition": "library.checkout.delivery.cond_pickup_checks",
          "stepId": "delivery_pickup_checks"
        }
      ]
    },
    {
      "id": "library.checkout.pipe_order_basics",
      "type": "pipeline",
      "description": "Общие проверки корзины и суммы заказа: используются и в обычном, и в B2B-заказе",
      "entrypoint": false,
      "strict": false,
      "required_context": [
        "minOrderAmount"
      ],
      "flow": [
        {
          "rule": "library.checkout.order.amount_required",
          "stepId": "order_amount_required"
        },
        {
          "condition": "library.checkout.order.cond_amount_min_if_present",
          "stepId": "order_amount_min_if_present"
        },
        {
          "rule": "library.checkout.order.currency_allowed",
          "stepId": "order_currency_allowed"
        },
        {
          "rule": "library.checkout.order.items_qty_positive",
          "stepId": "order_items_qty_positive"
        },
        {
          "rule": "library.checkout.order.items_sku_format",
          "stepId": "order_items_sku_format"
        }
      ]
    },
    {
      "id": "library.checkout.customer.pred_email_filled",
      "type": "rule",
      "description": "Электронная почта заполнена",
      "role": "predicate",
      "operator": "not_empty",
      "field": "customer.email"
    },
    {
      "id": "library.checkout.customer.pred_phone_filled",
      "type": "rule",
      "description": "Телефон заполнен",
      "role": "predicate",
      "operator": "not_empty",
      "field": "customer.phone"
    },
    {
      "id": "library.checkout.delivery.pred_type_courier",
      "type": "rule",
      "description": "Выбрана курьерская доставка",
      "role": "predicate",
      "operator": "equals",
      "field": "delivery.type",
      "value": "COURIER"
    },
    {
      "id": "library.checkout.delivery.pred_type_pickup",
      "type": "rule",
      "description": "Выбран самовывоз",
      "role": "predicate",
      "operator": "equals",
      "field": "delivery.type",
      "value": "PICKUP"
    },
    {
      "id": "library.checkout.order.pred_amount_filled",
      "type": "rule",
      "description": "Сумма заказа заполнена",
      "role": "predicate",
      "operator": "not_empty",
      "field": "order.amount"
    }
  ],
  "meta": {
    "projectId": "polka-checkout",
    "projectTitle": "Полка — проверки",
    "description": "Пакет правил магазина «Полка»: оформление заказа, профиль покупателя, возврат, B2B-заказ",
    "rulesetVersion": "1.1.0"
  }
}
